# Copy to .env (or .env.alt for a second stack) and adjust as needed.
# docker-compose loads .env automatically; pass other env files with
#   docker compose --env-file .env.alt up -d

# --- Identity ----------------------------------------------------------
# Compose project name. All containers and the postgres volume are
# named "${COMPOSE_PROJECT_NAME}-..." so multiple stacks coexist cleanly.
COMPOSE_PROJECT_NAME=gpcrdb

# --- Host-side ports ---------------------------------------------------
# Change only if the defaults conflict, or for a second stack.
APP_PORT=8000
DB_PORT=5432
ADMINER_PORT=8888

# --- Host-side paths to the protwis source and the GPCRdb data tree ---
# Defaults assume ~/GitHub/protwis, ~/GitHub/gpcrdb_data side-by-side.
PROTWIS_SRC=../protwis
PROTWIS_GPCRDB_DATA=../gpcrdb_data

# --- Optional: override DB credentials (must match across all services) -
# POSTGRES_USER=protwis
# POSTGRES_PASSWORD=protwis
# POSTGRES_DB=protwis

# --- Optional: override Django settings driven by the env --------------
# DJANGO_SECRET_KEY=
# DJANGO_DEBUG=True
# DJANGO_ALLOWED_HOSTS=*
