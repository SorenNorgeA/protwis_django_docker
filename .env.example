# Copy to .env to override defaults. docker-compose loads .env automatically.

# Path to the protwis Django source repo (clone of github.com/protwis/protwis).
# Bind-mounted to /app/src in the container.
PROTWIS_SRC=../protwis

# Path to the GPCRdb data repo (clone of github.com/protwis/gpcrdb_data).
# Bind-mounted to /app/data/protwis/gpcr in the container.
PROTWIS_GPCRDB_DATA=../gpcrdb_data

# --- Optional overrides (rarely needed for local dev) ---

# Django secret key. Local dev has a built-in default; production REQUIRES this.
# DJANGO_SECRET_KEY=

# Comma-separated list of allowed hosts. Default for local dev: *
# DJANGO_ALLOWED_HOSTS=

# DB credentials (must match the `db` service env). Defaults: protwis/protwis/protwis.
# POSTGRES_HOST=db
# POSTGRES_PORT=5432
# POSTGRES_USER=protwis
# POSTGRES_PASSWORD=protwis
# POSTGRES_DB=protwis
